---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import {ViewTransitions} from 'astro:transitions';
import MainLayout from "./Main.astro";
import { blogPostingNode } from '../lib/schema';

type Props = CollectionEntry<'blog'>['data'];

const { title, subtitle, description, pubDate, updatedDate, heroImage, customHeroImageLocation } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const blogPosting = blogPostingNode({ url: canonicalURL, title, description, pubDate, updatedDate, heroImage });
---

<MainLayout title={title} subtitle={subtitle} description={description} image={heroImage} jsonLd={[blogPosting]}>
	<article>
		{ heroImage && !customHeroImageLocation && (
			<div class="hero-image">
				{<img src={heroImage} alt="Header image " />}
			</div>
		)}
		<small class="date">
			By Josh Moody —
			{
				pubDate && (
					<>Published: <FormattedDate date={pubDate} /></>
				)
			}
			{
				updatedDate && (
					<>— Updated: <FormattedDate date={updatedDate} /></>
				)
			}
		</small>
		<slot />
	</article>
</MainLayout>
