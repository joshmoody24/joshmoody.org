---
import { baseGraph } from '../lib/schema';

interface Props {
	nodes?: object[];
}

const { nodes = [] } = Astro.props;

const graph = {
	'@context': 'https://schema.org',
	'@graph': [...baseGraph(), ...nodes],
};
---

<script type="application/ld+json" set:html={JSON.stringify(graph)} is:inline />
