---
interface Props {
  number: number;
}

const { number } = Astro.props;
---

<sup id={`footnote-${number}-ref`}><button
  type="button"
  aria-label={`Show footnote ${number}`}
  aria-controls={`footnote-${number}`}
  popovertarget={`footnote-${number}`}
  popovertargetaction="toggle"
>{number}</button></sup>

<style>
  sup {
    color: var(--color-primary);
    vertical-align: super;
    line-height: 0;
    font-size: 0.833rem;
    font-weight: normal;
    font-style: normal;
  }

  button {
    all: unset;
    cursor: pointer;
    text-decoration: underline;
  }
</style>
